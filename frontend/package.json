{
  "name": "mousefit-v2-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch{}\" && next dev",
    "dev:webpack": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch{}\" && next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "clean:next": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch{}\"",
    "test": "node --test tests/**/*.test.mjs"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.40.0",
    "framer-motion": "^12.29.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.4",
    "nodemailer": "^7.0.12",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
