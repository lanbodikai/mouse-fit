# Shared env used by Docker image builds and container startup.
# This file is fetched by default from:
# https://raw.githubusercontent.com/lanbodikai/mouse-fit/main/.env.compose
#
# Compose build-time env source (used by docker-compose.yml build args).
MOUSEFIT_ENV_URL=https://raw.githubusercontent.com/lanbodikai/mouse-fit/main/.env.compose

# Backend runtime
PYTHONUNBUFFERED=1
WEB_CONCURRENCY=2
MOUSEFIT_WARMUP_RAG=1
MOUSEFIT_SEED_MICE=if_empty
MOUSEFIT_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
GROQ_API_KEY=
GROQ_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant

# Backend CORS config (defaults match backend/main.py)
CORS_ALLOW_ORIGINS=
CORS_ALLOW_ORIGIN_REGEX=^https://((mouse-fit|mousefit)(?:-[a-z0-9-]+)?\.vercel\.app|([a-z0-9-]+\.)?mousefit\.pro)$

# Backend model path config (defaults match backend/backend/config.py)
MOUSEFIT_ONNX_PATH=/app/backend/backend/ml/model/models/best.onnx
MOUSEFIT_PT_PATH=/app/backend/backend/ml/model/models/best.pt
MOUSEFIT_TF_PATH=/app/backend/backend/ml/model/models/best.pb

# Frontend runtime/build
NODE_ENV=production
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Contact API (frontend server route)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=lanbodikai@gmail.com
SMTP_PASS="oxyg tknk seng ypya"
CONTACT_TO=lanbodikai@gmail.com
CONTACT_FROM="MouseFit <YOUR_GMAIL@gmail.com>"

# Script-only variables (used by backend/scripts/*.py)
MOUSEFIT_API_BASE=http://localhost:8000
MOUSEFIT_ORIGIN=https://mousefit.pro
